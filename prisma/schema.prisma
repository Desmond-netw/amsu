// This is your Prisma schema file,

generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model Admin {
  id String @id @default(uuid())
  username String @unique
}

model User {
  id String @id @default(uuid())
  username String @unique
  firstName String
  lastName String
  email String @unique
  phone String?
  address String?
  img String?
  sex UserSex?
  createdAt DateTime @default(now())
  // relations
  requestId String?
  request Request? @relation(fields: [requestId], references: [id])

}

model Request {
  id              String        @id @default(cuid())
  fullName        String
  serviceRequired String
  phone           String
  location        String
  facilityType    String
  preferredDate   DateTime
  description     String
  attachmentUrl   String?       // Stores the URL or path of the uploaded file
  status          RequestStatus @default(IN_PROGRESS)
  statusComment   String?
  statusUpdatedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  // relations
  users User[]
  customer Customer[]

  @@map("requests")
}

model ProjectsReg {
  id String @id @default(uuid())
  sn String @unique // Serial Number
  description String?
  projectlocation String?
  clientName String?
  createdAt DateTime @default(now())
}

model ProjectsPortfolio {
  id String @id @default(uuid())
  title String
  description String?
  img String?
  createdAt DateTime @default(now())
}

model Contacts {
  id String @id @default(uuid())
  fullName String
  phone String
  email String?
  Subject String
  message String
  createdAt DateTime @default(now())
}

model Customer {
  id String @id @default(uuid())
  name String
  email String @unique
  phone String
  address String?
  createdAt DateTime @default(now())
  // relations
  requestId String? @unique
  request Request? @relation(fields: [requestId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  category  String   // e.g., "Maintenance", "Urgent", "General"
  tagColor  String   // "brand" or "yellow"
  title     String
  desc      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

enum UserSex {
  MALE
  FEMALE
}

enum RequestStatus {
  IN_PROGRESS       @map("In Progress")
  ON_HOLD          @map("On Hold")
  COMPLETED         @map("Completed")
}